/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:; connect-src 'self' https://api.formspree.io https://formspree.io; frame-ancestors 'none'; form-action 'self' https://formspree.io https://api.formspree.io; base-uri 'self'; object-src 'none'

# CSS and JS revalidate every load. Filenames aren't hashed, so caching
# them risks serving stale CSS alongside fresh HTML — which is exactly
# what bit us when the skip-link rolled out (cached old CSS + new HTML
# broke margin-collapse and created a visible gap below the nav).
# Browsers send If-None-Match and we serve 304 if unchanged, so the
# bandwidth cost is negligible.
/css/*
  Cache-Control: public, max-age=0, must-revalidate

/js/*
  Cache-Control: public, max-age=0, must-revalidate

# Images and fonts can stay cached — we rarely change those, and when we
# do it tends to be deliberate (new photo, new font weight).
/img/*
  Cache-Control: public, max-age=3600

/fonts/*
  Cache-Control: public, max-age=3600

# Root-level icons (Netlify applies rules cumulatively, so we list these
# explicitly rather than using /*.png or /*.ico wildcards that would also
# match files under /img/ and produce duplicate Cache-Control headers).
/favicon.ico
  Cache-Control: public, max-age=3600

/favicon.png
  Cache-Control: public, max-age=3600

/apple-touch-icon.png
  Cache-Control: public, max-age=3600

/apple-touch-icon-precomposed.png
  Cache-Control: public, max-age=3600

# HTML — always revalidate so updates appear immediately
/*.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate
